---
import "../styles/global.css";
import Navbar from "../components/Navbar.svelte";
import Footer from "../components/Footer.svelte";
import PricingCard from "../components/PricingCard.svelte";
import InsightCard from "../components/InsightCard.svelte";
import Button from "../components/Button.svelte";
---

<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Sorelabs — Digital Business Specialist</title>
		<meta name="description" content="We analyze and create your digital business plan. Get the blueprint for traffic distribution architecture and conversion strategies." />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap" rel="stylesheet">
		<meta name="p:domain_verify" content="b2d9fb7d113f2424a53a71c97a8c218f"/>
	</head>
	<body class="bg-background text-foreground selection:bg-accent selection:text-background relative">
		<Navbar client:load />

		<!-- Subtle Background Decorations -->
		<div class="fixed top-0 left-0 w-full h-full -z-10 pointer-events-none overflow-hidden">
			<div class="absolute top-[-10%] right-[-10%] w-[50%] h-[50%] bg-accent/5 blur-[120px] rounded-full"></div>
			<div class="absolute top-[40%] left-[-10%] w-[30%] h-[40%] bg-accent/5 blur-[150px] rounded-full"></div>
			<div class="absolute bottom-[-10%] right-[10%] w-[40%] h-[40%] bg-accent/10 blur-[150px] rounded-full"></div>
		</div>

		<main class="flex flex-col items-center w-full">
			
			<!-- 1. HERO SECTION -->
			<section class="min-h-[90vh] flex flex-col items-center justify-center px-4 pt-32 pb-24 max-w-7xl mx-auto w-full text-center relative">
				<div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-white/80 text-sm font-medium tracking-wide mb-8 animate-fade-in">
					<span class="relative flex h-3 w-3">
					  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
					  <span class="relative inline-flex rounded-full h-3 w-3 bg-accent"></span>
					</span>
					Analyze. Strategize. Execute.
				</div>

				<h1 class="text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-black tracking-tighter mb-8 uppercase text-center break-words px-2 animate-slide-up leading-[0.85]">
					We analyze and make your <br/>
					<span class="text-accent">digital business plan.</span>
				</h1>
				
				<p class="text-xl md:text-2xl text-muted max-w-3xl mx-auto mb-12 animate-slide-up-delayed leading-relaxed">
					We build traffic distribution architecture and conversion strategies. <br class="hidden md:block"/>
					<strong class="text-white font-semibold">You get the blueprint, not just a website. ☀</strong>
				</p>

				<div class="animate-fade-in-delayed flex flex-col sm:flex-row gap-6 items-center">
					<Button href="#pricing" variant="primary">
						START CONSULTING NOW
					</Button>
					<a href="mailto:myslatudio@gmail.com?subject=Consultation%20Inquiry:%20Digital%20Business%20Plan%20for%20[Business%20Name]&body=Hi%20Kresna,%0D%0AMy%20business%20is:%20[Name/URL]%0D%0AOur%20main%20challenge%20right%20now%20is:%20[Challenge]%0D%0AI%20confirm%20that%20we%20are%20ready%20to%20invest%20$1,000%20for%20the%20full%20digital%20business%20plan.%0D%0ALet%27s%20start%20consulting." target="_blank" rel="noopener noreferrer" class="text-muted hover:text-white transition-colors underline-offset-4 hover:underline font-medium">
						Or let's talk via Email ->
					</a>
				</div>
			</section>

			<!-- 2. FEATURE SECTION -->
			<section id="features" class="w-full py-32 px-4 border-y border-white/5 bg-black/50 backdrop-blur-md">
				<div class="max-w-7xl mx-auto">
					<div class="text-center mb-20">
						<h2 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">The Strategic Blueprint</h2>
						<p class="text-muted text-lg max-w-2xl mx-auto">Output that transforms your operation, not just lines of code.</p>
					</div>

					<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
						<!-- Feature 1 -->
						<div class="p-8 rounded-3xl glass border-t-accent/50 border-t-2 hover:-translate-y-2 transition-transform duration-300">
							<div class="w-14 h-14 bg-white/5 rounded-2xl flex items-center justify-center mb-6">
								<svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
								</svg>
							</div>
							<h3 class="text-2xl font-bold mb-3">Audit & Diagnosis</h3>
							<p class="text-muted">Identifying the bottlenecks in your digital ecosystem. We find out exactly why your business is stuck and how to fix it.</p>
						</div>

						<!-- Feature 2 -->
						<div class="p-8 rounded-3xl glass border-t-accent/50 border-t-2 hover:-translate-y-2 transition-transform duration-300">
							<div class="w-14 h-14 bg-white/5 rounded-2xl flex items-center justify-center mb-6">
								<svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
								</svg>
							</div>
							<h3 class="text-2xl font-bold mb-3">Traffic Roadmap</h3>
							<p class="text-muted">Strategic distribution through Pinterest Automation and GBP Audit. We build the path to bring the right eyes to your brand.</p>
						</div>

						<!-- Feature 3 -->
						<div class="p-8 rounded-3xl glass border-t-accent/50 border-t-2 hover:-translate-y-2 transition-transform duration-300">
							<div class="w-14 h-14 bg-white/5 rounded-2xl flex items-center justify-center mb-6">
								<svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
								</svg>
							</div>
							<h3 class="text-2xl font-bold mb-3">Tech-Stack Advice</h3>
							<p class="text-muted">Expert guidance on technologies like Astro and Svelte. We give your IT team the exact tools they need to execute perfectly.</p>
						</div>
					</div>
				</div>
			</section>

			<!-- 3. PRICING SECTION -->
			<section id="pricing" class="w-full py-32 px-4 relative">
				<div class="max-w-7xl mx-auto">
					<div class="text-center mb-20">
						<h2 class="text-4xl md:text-6xl font-black tracking-tight mb-6 uppercase">The Investment</h2>
						<p class="text-muted text-lg max-w-2xl mx-auto">Investment starts at $1,000 for a full digital business plan. No fluff, just performance.</p>
					</div>
					
					<div class="max-w-xl mx-auto w-full">
						<PricingCard 
							client:visible
							isPremium={true}
							name="Digital Business Plan"
							price="$1,000+"
							features={[
								"Audit & Diagnosis",
								"Traffic Distribution Roadmap",
								"Pinterest Automation Blueprint",
								"GBP Audit & Strategy",
								"Tech-Stack Recommendation (Astro/Svelte)",
								"Conversion Strategy Blueprint"
							]}
						/>
					</div>
				</div>
			</section>

			<!-- 4. THE TRUTH SECTION (Replacing Social Proof) -->
			<section id="proof" class="w-full py-32 px-4 border-t border-white/5 bg-black/30">
				<div class="max-w-7xl mx-auto">
					<div class="text-center mb-16">
						<h2 class="text-3xl md:text-5xl font-bold tracking-tight mb-4 uppercase">The Growth Bottlenecks</h2>
						<p class="text-muted text-lg max-w-2xl mx-auto">Identifying the hidden digital issues that are stalling your progress—and how we fix them.</p>
					</div>

					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
						<InsightCard 
							step="01"
							title="The Visibility Engine"
							description="Most brands suffer from 'Ghost Website Syndrome'—great design, zero traffic. We fix this by auditing your Google Business Profile and implementing Pinterest Automation. We don't just build a destination; we build the traffic distribution architecture that feeds your business."
						/>
						<InsightCard 
							step="02"
							title="Blueprint vs Building"
							description="Building without a blueprint is expensive guesswork. Our Digital Business Plan is a deep-dive diagnosis that uncovers why your growth is stalled. You receive a strategic operational document—a system that dictates how you attract, engage, and convert—long before the coding starts."
						/>
						<InsightCard 
							step="03"
							title="The Tech Advantage"
							description="Clunky platforms and generic builders are silent revenue killers. We leverage the power of Astro and Svelte to create high-velocity digital assets. Our tech-stack recommendations ensure your IT team isn't fighting the tools, but using them to drive precision and profit."
						/>
					</div>
				</div>
			</section>

			<!-- 5. CTA SECTION -->
			<section class="w-full py-32 px-4 relative overflow-hidden">
				<!-- CTA Background Glow -->
				<div class="absolute inset-0 flex items-center justify-center -z-10 pointer-events-none">
					<div class="w-[800px] h-[400px] bg-accent/20 blur-[150px] rounded-full"></div>
				</div>

				<div class="max-w-4xl mx-auto text-center glass p-12 md:p-20 rounded-[3rem] relative border-accent/20">
					<h2 class="text-4xl md:text-6xl font-black tracking-tight mb-6 uppercase">
						Ready to receive your blueprint?
					</h2>
					<p class="text-xl text-muted mb-12 max-w-2xl mx-auto">
						Stop guessing. Start executing with a strategic plan tailored to your business goals.
					</p>
					
					<a 
						href="mailto:myslatudio@gmail.com?subject=Consultation%20Inquiry:%20Digital%20Business%20Plan%20for%20[Business%20Name]&body=Hi%20Kresna,%0D%0A%0D%0AMy%20business%20is:%20[Name/URL]%0D%0AOur%20main%20challenge%20right%20now%20is:%20[Challenge]%0D%0A%0D%0AI%20confirm%20that%20we%20are%20ready%20to%20invest%20$1,000%20for%20the%20full%20digital%20business%20plan.%0D%0A%0D%0ALet%27s%20start%20consulting."
						target="_blank"
						rel="noopener noreferrer"
						class="inline-block px-12 py-6 bg-white text-black font-black text-xl rounded-2xl hover:bg-gray-200 transition-all hover:scale-105 shadow-[0_10px_40px_rgba(255,255,255,0.1)] hover:shadow-[0_15px_60px_rgba(255,255,255,0.2)] uppercase tracking-widest"
					>
						Start Consulting Now
					</a>
				</div>
			</section>

		</main>

		<Footer />

		<style>
			@keyframes fadeIn {
				from { opacity: 0; }
				to { opacity: 1; }
			}
			@keyframes slideUp {
				from { opacity: 0; transform: translateY(30px); }
				to { opacity: 1; transform: translateY(0); }
			}
			.animate-fade-in { animation: fadeIn 1s ease-out forwards; }
			.animate-fade-in-delayed { animation: fadeIn 1s ease-out 0.8s forwards; opacity: 0; }
			.animate-slide-up { animation: slideUp 1s ease-out forwards; }
			.animate-slide-up-delayed { animation: slideUp 1s ease-out 0.4s forwards; opacity: 0; }
		</style>
	</body>
</html>

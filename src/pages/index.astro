---
import "../styles/global.css";
import Navbar from "../components/Navbar.svelte";
import Footer from "../components/Footer.svelte";
import PricingCard from "../components/PricingCard.svelte";
import InsightCard from "../components/InsightCard.svelte";
import Button from "../components/Button.svelte";
---

<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Sorelabs — Your Digital Partner</title>
		<meta name="description" content="We handle your digital infrastructure so you can focus on scaling. High-performance landing pages, growth optimization, and visual ecosystems." />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap" rel="stylesheet">
		<meta name="p:domain_verify" content="719e162c90d39a39c7049655ba37ca6b"/>
	</head>
	<body class="bg-background text-foreground selection:bg-accent selection:text-background relative">
		<Navbar client:load />

		<!-- Subtle Background Decorations -->
		<div class="fixed top-0 left-0 w-full h-full -z-10 pointer-events-none overflow-hidden">
			<div class="absolute top-[-10%] right-[-10%] w-[50%] h-[50%] bg-accent/5 blur-[120px] rounded-full"></div>
			<div class="absolute top-[40%] left-[-10%] w-[30%] h-[40%] bg-accent/5 blur-[150px] rounded-full"></div>
			<div class="absolute bottom-[-10%] right-[10%] w-[40%] h-[40%] bg-accent/10 blur-[150px] rounded-full"></div>
		</div>

		<main class="flex flex-col items-center w-full">
			
			<!-- 1. HERO SECTION -->
			<section class="min-h-[90vh] flex flex-col items-center justify-center px-4 pt-32 pb-24 max-w-7xl mx-auto w-full text-center relative">
				<div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-white/80 text-sm font-medium tracking-wide mb-8 animate-fade-in">
					<span class="relative flex h-3 w-3">
					  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
					  <span class="relative inline-flex rounded-full h-3 w-3 bg-accent"></span>
					</span>
					Scale your business online
				</div>

				<h1 class="text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-black tracking-tighter mb-8 uppercase text-center break-words px-2 animate-slide-up leading-[0.85]">
					Sorelabs <br/>
					<span class="text-accent">Digital Partner.</span>
				</h1>
				
				<p class="text-xl md:text-2xl text-muted max-w-3xl mx-auto mb-12 animate-slide-up-delayed leading-relaxed">
					We handle your digital infrastructure so you can focus on scaling. <br class="hidden md:block"/>
					<strong class="text-white font-semibold">Let’s connect and build. ☀</strong>
				</p>

				<div class="animate-fade-in-delayed flex flex-col sm:flex-row gap-6 items-center">
					<Button href="#pricing" variant="primary">
						VIEW OUR PLANS
					</Button>
					<a href="mailto:myslatudio@gmail.com?subject=Inquiry:%20High-Performance%20Infrastructure%20for%20[Business%20Name]&body=Hi%20Kresna,%0D%0AMy%20business%20is:%20[Name/URL]%0D%0AOur%20main%20goal%20with%20this%20project%20is:%20[Goal]%0D%0AOur%20target%20launch%20date%20is:%20[Date]%0D%0AI%20confirm%20that%20we%20are%20ready%20to%20invest%20in%20the%20$3,000+%20premium%20standard.%0D%0ALet%27s%20build%20something%20fast." target="_blank" rel="noopener noreferrer" class="text-muted hover:text-white transition-colors underline-offset-4 hover:underline font-medium">
						Or let's talk via Email ->
					</a>
				</div>
			</section>

			<!-- 2. FEATURE SECTION -->
			<section id="features" class="w-full py-32 px-4 border-y border-white/5 bg-black/50 backdrop-blur-md">
				<div class="max-w-7xl mx-auto">
					<div class="text-center mb-20">
						<h2 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">Why Businesses Partner With Us</h2>
						<p class="text-muted text-lg max-w-2xl mx-auto">It's not just a website. It's digital infrastructure designed to scale your brand with zero friction.</p>
					</div>

					<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
						<!-- Feature 1 -->
						<div class="p-8 rounded-3xl glass border-t-accent/50 border-t-2 hover:-translate-y-2 transition-transform duration-300">
							<div class="w-14 h-14 bg-white/5 rounded-2xl flex items-center justify-center mb-6">
								<svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
								</svg>
							</div>
							<h3 class="text-2xl font-bold mb-3">Instant Loading</h3>
							<p class="text-muted">Built on Astro. Zero JavaScript overhead by default. Pages load in milliseconds, drastically dropping bounce rates.</p>
						</div>

						<!-- Feature 2 -->
						<div class="p-8 rounded-3xl glass border-t-accent/50 border-t-2 hover:-translate-y-2 transition-transform duration-300">
							<div class="w-14 h-14 bg-white/5 rounded-2xl flex items-center justify-center mb-6">
								<svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.813-1.425a1.5 1.5 0 00.834-1.942 1.5 1.5 0 00-1.942-.834l-1.425 3.813a15.995 15.995 0 00-4.648 4.764m-3.42-3.42a16.008 16.008 0 00-4.648-4.764l-3.813 1.425A1.5 1.5 0 002.25 12c0 .248.06.48.163.684l1.425-3.813" />
								</svg>
							</div>
							<h3 class="text-2xl font-bold mb-3">Aesthetic & Premium</h3>
							<p class="text-muted">Interactive Svelte components, glassmorphism, and micro-animations that make your brand feel untouchable.</p>
						</div>

						<!-- Feature 3 -->
						<div class="p-8 rounded-3xl glass border-t-accent/50 border-t-2 hover:-translate-y-2 transition-transform duration-300">
							<div class="w-14 h-14 bg-white/5 rounded-2xl flex items-center justify-center mb-6">
								<svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
								</svg>
							</div>
							<h3 class="text-2xl font-bold mb-3">Enterprise Infrastructure</h3>
							<p class="text-muted">We handle the tech. You get a ready-to-launch ecosystem hosted on secure, globally distributed infrastructure. Zero maintenance required.</p>
						</div>
					</div>
				</div>
			</section>

			<!-- 3. PRICING SECTION -->
			<section id="pricing" class="w-full py-32 px-4 relative">
				<div class="max-w-7xl mx-auto">
					<div class="text-center mb-20">
						<h2 class="text-4xl md:text-6xl font-black tracking-tight mb-6 uppercase">Service Ecosystem</h2>
						<p class="text-muted text-lg max-w-2xl mx-auto">Flexible plans designed to grow with your business. No fluff, just performance.</p>
					</div>
					
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
						<PricingCard 
							client:visible
							name="Single-Page Asset"
							price="$3,000"
							features={[
								"5 Shot Pitch Section",
								"Copy of your Product",
								"Performance Tracking",
								"2 Revision"
							]}
						/>
						<PricingCard 
							client:visible
							isPremium={true}
							name="Growth & Optimization"
							price="$1,500"
							billing="/ month"
							features={[
								"A/B Testing",
								"Monthly Performance Report",
								"Unlimited Tweaks",
								"Conversion Rate Optimization"
							]}
						/>
						<PricingCard 
							client:visible
							name="Infrastructure & Support"
							price="$500"
							billing="/ month"
							features={[
								"Managed Hosting",
								"Uptime Monitoring",
								"1-2 Hours of technical help per month",
								"Security Updates"
							]}
						/>
						<PricingCard 
							client:visible
							name="Content & Visuals"
							price="$2,000"
							billing="/ month"
							features={[
								"Monthly visual asset design",
								"Promo landing page updates",
								"Social Media Kit",
								"Custom Illustrations"
							]}
						/>
					</div>
				</div>
			</section>

			<!-- 4. THE TRUTH SECTION (Replacing Social Proof) -->
			<section id="proof" class="w-full py-32 px-4 border-t border-white/5 bg-black/30">
				<div class="max-w-7xl mx-auto">
					<div class="text-center mb-16">
						<h2 class="text-3xl md:text-5xl font-bold tracking-tight mb-4 uppercase">The Infrastructure Gap</h2>
						<p class="text-muted text-lg max-w-2xl mx-auto">Why standard setups are costing you fortunes—and how we bridge the gap.</p>
					</div>

					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
						<InsightCard 
							step="01"
							title="Death by a Thousand Options"
							description="Traditional multi-page websites are distractions, not assets. They confuse visitors and kill momentum. We build Single-Page Sales Engines that eliminate the noise, simplify the journey, and force a decision. The result? A conversion rate that actually moves the needle."
						/>
						<InsightCard 
							step="02"
							title="Speed is a Financial Metric"
							description="A 1-second delay isn't just a lag; it’s a 7% leak in your revenue. While your competitors struggle with bloated templates, we engineer on Astro. By stripping away the 'JavaScript junk,' we deliver instant-load experiences. The logic is simple: If they don't wait, they don't leave. If they stay, they buy."
						/>
						<InsightCard 
							step="03"
							title="The End of 'Good Enough'"
							description="Clunky page builders and generic templates tell your clients you’re average. We use Svelte to craft bespoke, interactive digital assets that feel as premium as your service. Our standard: We don't just build sites; we engineer high-performance systems that position you as the only logical choice in your market."
						/>
					</div>
				</div>
			</section>

			<!-- 5. CTA SECTION -->
			<section class="w-full py-32 px-4 relative overflow-hidden">
				<!-- CTA Background Glow -->
				<div class="absolute inset-0 flex items-center justify-center -z-10 pointer-events-none">
					<div class="w-[800px] h-[400px] bg-accent/20 blur-[150px] rounded-full"></div>
				</div>

				<div class="max-w-4xl mx-auto text-center glass p-12 md:p-20 rounded-[3rem] relative border-accent/20">
					<h2 class="text-4xl md:text-6xl font-black tracking-tight mb-6 uppercase">
						Ready to scale with a partner?
					</h2>
					<p class="text-xl text-muted mb-12 max-w-2xl mx-auto">
						We take your business as seriously as you do. Let's talk about your vision and how we can help you scale with precision.
					</p>
					
					<a 
						href="mailto:myslatudio@gmail.com?subject=Inquiry:%20High-Performance%20Infrastructure%20for%20[Business%20Name]&body=Hi%20Kresna,%0D%0A%0D%0AMy%20business%20is:%20[Name/URL]%0D%0AOur%20main%20goal%20with%20this%20project%20is:%20[Goal]%0D%0AOur%20target%20launch%20date%20is:%20[Date]%0D%0A%0D%0AI%20confirm%20that%20we%20are%20ready%20to%20invest%20in%20the%20$3,000+%20premium%20standard.%0D%0A%0D%0ALet%27s%20build%20something%20fast."
						target="_blank"
						rel="noopener noreferrer"
						class="inline-block px-12 py-6 bg-white text-black font-black text-xl rounded-2xl hover:bg-gray-200 transition-all hover:scale-105 shadow-[0_10px_40px_rgba(255,255,255,0.1)] hover:shadow-[0_15px_60px_rgba(255,255,255,0.2)] uppercase tracking-widest"
					>
						Let's Connect
					</a>
				</div>
			</section>

		</main>

		<Footer />

		<style>
			@keyframes fadeIn {
				from { opacity: 0; }
				to { opacity: 1; }
			}
			@keyframes slideUp {
				from { opacity: 0; transform: translateY(30px); }
				to { opacity: 1; transform: translateY(0); }
			}
			.animate-fade-in { animation: fadeIn 1s ease-out forwards; }
			.animate-fade-in-delayed { animation: fadeIn 1s ease-out 0.8s forwards; opacity: 0; }
			.animate-slide-up { animation: slideUp 1s ease-out forwards; }
			.animate-slide-up-delayed { animation: slideUp 1s ease-out 0.4s forwards; opacity: 0; }
		</style>
	</body>
</html>

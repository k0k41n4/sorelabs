---
import "../styles/global.css";
import Navbar from "../components/Navbar.svelte";
import Footer from "../components/Footer.svelte";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>Services | SORELABS</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap" rel="stylesheet">
	</head>
	<body class="bg-background text-foreground">
		<Navbar client:load />
		
		<main class="min-h-screen pt-40 px-4 pb-32 max-w-7xl mx-auto text-center overflow-hidden">
			<h1 class="text-5xl sm:text-7xl md:text-8xl font-bold uppercase mb-8 break-words px-2">Services</h1>
			<p class="text-xl text-muted max-w-2xl mx-auto break-words px-4">
				From landing pages to enterprise systems, we build what sells.
			</p>
			<div class="mt-20 flex flex-col gap-10 w-full">
				<div class="p-10 border border-white/10 rounded-xl glass flex flex-col md:flex-row justify-between items-center gap-6 text-center md:text-left">
					<div>
						<h2 class="text-3xl font-bold mb-2">Bespoke Landing Pages</h2>
						<p class="text-muted">High-converting, minimalist designs.</p>
					</div>
					<div class="text-accent font-bold text-xl">$3,000+</div>
				</div>
				<div class="p-10 border border-white/10 rounded-xl glass flex flex-col md:flex-row justify-between items-center gap-6 text-center md:text-left">
					<div>
						<h2 class="text-3xl font-bold mb-2">Interactive Web Apps</h2>
						<p class="text-muted">Svelte 5 powered performance.</p>
					</div>
					<div class="text-accent font-bold text-xl">$7,500+</div>
				</div>
				<div class="p-10 border border-white/10 rounded-xl glass flex flex-col md:flex-row justify-between items-center gap-6 text-center md:text-left">
					<div>
						<h2 class="text-3xl font-bold mb-2">Enterprise SaaS</h2>
						<p class="text-muted">Scalable, future-proof foundations.</p>
					</div>
					<div class="text-accent font-bold text-xl">Let's Talk</div>
				</div>
			</div>
		</main>

		<Footer />
	</body>
</html>

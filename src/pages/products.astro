---
import "../styles/global.css";
import Navbar from "../components/Navbar.svelte";
import Footer from "../components/Footer.svelte";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>Products | SORELABS</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap" rel="stylesheet">
	</head>
	<body class="bg-background text-foreground">
		<Navbar client:load />
		
		<main class="min-h-screen pt-40 px-4 pb-16 max-w-7xl mx-auto text-center overflow-hidden">
			<h1 class="text-5xl sm:text-7xl md:text-8xl font-bold uppercase mb-8 break-words px-2">Products</h1>
			<p class="text-xl text-muted max-w-2xl mx-auto break-words px-4">
				Innovative digital tools and platforms crafted by Sorelabs.
			</p>
			<div class="mt-20 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 w-full">
				<div class="p-10 border border-white/10 rounded-xl glass hover:border-accent/50 transition-all group">
					<h2 class="text-3xl font-bold mb-4 group-hover:text-accent transition-colors">Sorecare</h2>
					<p class="text-muted">Jobboard for home care freelance services.</p>
				</div>
				<div class="p-10 border border-white/10 rounded-xl glass hover:border-accent/50 transition-all group">
					<h2 class="text-3xl font-bold mb-4 group-hover:text-accent transition-colors">Inivime</h2>
					<p class="text-muted">Premium digital card invitation platform.</p>
				</div>
				<div class="p-10 border border-white/10 rounded-xl glass hover:border-accent/50 transition-all group">
					<h2 class="text-3xl font-bold mb-4 group-hover:text-accent transition-colors">Pageooo</h2>
					<p class="text-muted">The ultimate e-catalog page maker for businesses.</p>
				</div>
				<div class="p-10 border border-white/10 rounded-xl glass hover:border-accent/50 transition-all group">
					<h2 class="text-3xl font-bold mb-4 group-hover:text-accent transition-colors">Oxcy</h2>
					<p class="text-muted">Your emotional friend and AI companion.</p>
				</div>
				<div class="p-10 border border-white/10 rounded-xl glass hover:border-accent/50 transition-all group">
					<h2 class="text-3xl font-bold mb-4 group-hover:text-accent transition-colors">Jreify</h2>
					<p class="text-muted">Trip plan curation with integrated booking system.</p>
				</div>
				<div class="p-10 border border-white/10 rounded-xl glass hover:border-accent/50 transition-all group">
					<h2 class="text-3xl font-bold mb-4 group-hover:text-accent transition-colors">Wanbe</h2>
					<p class="text-muted">Modern digital media platform.</p>
				</div>
			</div>
		</main>

		<Footer />
	</body>
</html>

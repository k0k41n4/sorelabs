---
import "../styles/global.css";
import Navbar from "../components/Navbar.svelte";
import Footer from "../components/Footer.svelte";
import Button from "../components/Button.svelte";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>About | SORELABS</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap" rel="stylesheet">
	</head>
	<body class="bg-background text-foreground">
		<Navbar client:load />
		
		<main class="pt-32 pb-16">
			
			<!-- Hero Section -->
			<section class="min-h-[80vh] flex flex-col justify-center px-4 max-w-7xl mx-auto mb-32 text-center md:text-left overflow-hidden">
				<div class="max-w-4xl mx-auto md:mx-0 w-full">
					<h1 class="text-4xl sm:text-7xl md:text-9xl font-bold tracking-tighter uppercase leading-[0.9] mb-12 animate-slide-up break-words">
						Build Value, <br class="hidden sm:block"/>
						<span class="text-muted">Not Just Software.</span>
					</h1>
					<p class="text-xl sm:text-2xl md:text-3xl text-muted leading-relaxed mb-12 animate-fade-in-delayed max-w-2xl mx-auto md:mx-0 break-words">
						High-end digital solutions designed for maximum performance and limitless scalability. We curate your ideas into essential products.
					</p>
					<div class="animate-slide-up-delayed flex justify-center md:justify-start">
						<Button href="https://wa.me/6289670202495" variant="primary">LET'S TALK &rarr;</Button>
					</div>
				</div>
			</section>

			<!-- Features Section -->
			<section class="px-4 max-w-7xl mx-auto mb-48">
				<div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
					<div class="p-8 border border-white/10 rounded-2xl glass hover:border-accent/30 transition-all flex flex-col items-center">
						<div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center text-accent mb-6">
							<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
						</div>
						<h3 class="text-2xl font-bold mb-4">Efficient Performance</h3>
						<p class="text-muted leading-relaxed text-lg">Lightweight code using modern stacks for uncompromising access speed.</p>
					</div>
					<div class="p-8 border border-white/10 rounded-2xl glass hover:border-accent/30 transition-all flex flex-col items-center">
						<div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center text-accent mb-6">
							<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" /></svg>
						</div>
						<h3 class="text-2xl font-bold mb-4">Purposeful Design</h3>
						<p class="text-muted leading-relaxed text-lg">Every visual element has a function. No redundant features. Functional Minimalism.</p>
					</div>
					<div class="p-8 border border-white/10 rounded-2xl glass hover:border-accent/30 transition-all flex flex-col items-center">
						<div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center text-accent mb-6">
							<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9h18" /></svg>
						</div>
						<h3 class="text-2xl font-bold mb-4">Global Scalability</h3>
						<p class="text-muted leading-relaxed text-lg">Architecture ready to handle international traffic from day one.</p>
					</div>
				</div>
			</section>


			<!-- Engagement Section -->
			<section class="px-4 max-w-7xl mx-auto mb-48 overflow-hidden">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center text-center lg:text-left">
					<div class="w-full">
						<h2 class="text-4xl sm:text-5xl md:text-7xl font-bold mb-8 uppercase break-words px-2">Digital <br class="hidden sm:block"/> Craftsmanship.</h2>
						<p class="text-lg sm:text-xl md:text-2xl text-muted leading-relaxed break-words px-4 sm:px-0">
							We don't just write code; we build ecosystems. From Micro-SaaS to complex management systems, our focus is on ROI and meaningful user experiences.
						</p>
					</div>
					<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
						<div class="p-10 border border-white/10 rounded-2xl bg-accent text-background">
							<div class="text-5xl font-black mb-2">99.9%</div>
							<div class="text-lg font-bold uppercase tracking-widest opacity-80">Uptime</div>
						</div>
						<div class="p-10 border border-white/10 rounded-2xl glass">
							<div class="text-5xl font-black mb-2 text-accent">Fast</div>
							<div class="text-lg font-bold uppercase tracking-widest text-muted">Delivery</div>
						</div>
						<div class="p-10 border border-white/10 rounded-2xl glass sm:col-span-2">
							<div class="text-5xl font-black mb-2 text-foreground">Clean</div>
							<div class="text-lg font-bold uppercase tracking-widest text-muted">Architecture & Scalable Systems</div>
						</div>
					</div>
				</div>
			</section>

			<!-- CTA Section -->
			<section class="px-4 max-w-7xl mx-auto mb-48 text-center overflow-hidden">
				<div class="p-8 sm:p-16 md:p-32 rounded-[2rem] sm:rounded-[3rem] border border-accent/20 bg-linear-to-b from-accent/10 to-transparent relative overflow-hidden">
					<h2 class="text-4xl sm:text-6xl md:text-8xl font-bold mb-8 uppercase leading-[0.9] break-words px-2">Ready to Build <br class="hidden sm:block"/> Something Meaningful?</h2>
					<p class="text-lg sm:text-xl md:text-2xl text-muted mb-16 max-w-2xl mx-auto break-words px-4">
						Let's discuss how we can bring more value to your business through the right technology.
					</p>
					<div class="flex flex-col sm:flex-row items-center justify-center gap-8">
						<Button href="https://wa.me/6289670202495" variant="primary">LET'S TALK</Button>
						<a href="/products" class="text-xl font-bold border-b-2 border-accent hover:text-accent transition-all">View Our Portfolio</a>
					</div>
					<!-- Deco background -->
					<div class="absolute top-0 right-0 w-64 h-64 bg-accent/20 blur-[100px] rounded-full -z-10"></div>
				</div>
			</section>

		</main>

		<Footer />

		<style>
			@keyframes slideUp {
				from { opacity: 0; transform: translateY(40px); }
				to { opacity: 1; transform: translateY(0); }
			}
			@keyframes fadeIn {
				from { opacity: 0; }
				to { opacity: 1; }
			}
			.animate-slide-up { animation: slideUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
			.animate-slide-up-delayed { animation: slideUp 1s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards; opacity: 0; }
			.animate-fade-in-delayed { animation: fadeIn 1.5s ease-out 0.4s forwards; opacity: 0; }
		</style>
	</body>
</html>
